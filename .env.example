# Server Configuration
PORT=8080
HOST=0.0.0.0

# Database Configuration
DATABASE_URL=postgres://sensor_user:sensor_password@localhost:5434/sensor_db
DB_MAX_CONNECTIONS=25
DB_MIN_CONNECTIONS=5

# Redis Configuration
REDIS_URL=redis://localhost:6380
