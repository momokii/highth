# Server Configuration
PORT=8080
HOST=0.0.0.0

# Database Credentials
# IMPORTANT: Change this password before deploying
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Database Configuration
DATABASE_URL=postgres://sensor_user:CHANGE_ME_POSTGRES_PASSWORD@postgres:5434/sensor_db?sslmode=disable
DB_MAX_CONNECTIONS=200
DB_MIN_CONNECTIONS=10
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=10m
DB_HEALTH_CHECK_PERIOD=30s

# Redis Configuration
# IMPORTANT: Change this password before deploying
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
REDIS_ENABLED=true
REDIS_TTL=30s
REDIS_POOL_SIZE=50
REDIS_MIN_IDLE_CONNS=10
REDIS_MAX_IDLE_CONNS=50
REDIS_CONN_MAX_IDLE_TIME=5m

# Cache Configuration
CACHE_ENABLED=true

# Application Configuration
LOG_LEVEL=info
REQUEST_TIMEOUT=30s
ENVIRONMENT=development
